generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectConfig {
  projectId String @id
  layout    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}