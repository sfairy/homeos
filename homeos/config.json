{
  "name": "Home OS",
  "version": "1.0.0",
  "slug": "homeos",
  "description": "Smart home control backend service with Home Assistant integration",
  "url": "https://github.com/sfairy/HomeOS",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "manual",
  "image": "ghcr.io/sfairy/homeos:{arch}-{version}",
  "ports": {
    "8125/tcp": 8125
  },
  "ports_description": {
    "8125/tcp": "Web UI and API port"
  },
  "environment": {
    "HA_URL": {
      "name": "Home Assistant URL",
      "description": "Home Assistant server address",
      "required": true,
      "default": "http://homeassistant:8123"
    },
    "HA_TOKEN": {
      "name": "Home Assistant Token",
      "description": "Home Assistant long-lived access token",
      "required": true,
      "default": ""
    },
    "JWT_SECRET": {
      "name": "JWT Secret",
      "description": "Secret key for JWT authentication",
      "required": false,
      "default": "shadow-super-secret-key-phase2"
    }
  },
  "options": {
    "ha_url": "http://homeassistant:8123",
    "ha_token": "",
    "jwt_secret": "shadow-super-secret-key-phase2"
  },
  "schema": {
    "ha_url": "str",
    "ha_token": "str",
    "jwt_secret": "str?"
  },
  "map": [],
  "devices": [],
  "privileged": [],
  "network": "host",
  "services": ["redis:rw"],
  "discovery": {},
  "panel_icon": "mdi:home-assistant"
}
